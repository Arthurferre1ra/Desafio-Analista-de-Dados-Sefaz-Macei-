# ==========================================================================
# .gitignore - Desafio Analise de Dados | Sefaz Maceio
# ==========================================================================

# --- Arquivos locais de ferramentas / assistentes -------------------------
.assistant/
*.local.md
.mcp.json

# --- Arquivos sensiveis / segredos ----------------------------------------
.env
.env.*
*.key
*.pem
*.p12
credentials*
secrets*
*.local

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version
.ipynb_checkpoints/

# --- Editores / IDEs ------------------------------------------------------
.vscode/
.idea/
*.swp

# --- Sistema operacional --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================================
# IMPORTANTE: dados_compactos/ nao deve ser ignorado. Os ZIPs originais fazem
# parte do desafio, e a primeira etapa do pipeline e descompacta-los por codigo.
#
# dados_extraidos/ e um artefato intermediario reproduzivel a partir dos ZIPs.
# ==========================================================================
dados_extraidos/
relatorios/logs/
